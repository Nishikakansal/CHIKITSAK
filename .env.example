# --- AI & ACCESS KEYS ---
# GEMINI_API_KEY: Required for AI triage & translation features.
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# GOOGLE_MAPS_API_KEY: Required for hospital maps and navigation.
# Get yours at: https://console.cloud.google.com/google/maps-apis/credentials
GOOGLE_MAPS_API_KEY="YOUR_GOOGLE_MAPS_API_KEY_HERE"

# --- DATABASE CONFIGURATION ---
# MONGODB_URI: Connection string for your MongoDB database.
# Format: mongodb+srv://<username>:<password>@cluster.mongodb.net/
MONGODB_URI="mongodb://localhost:27017/chikitsak"
DB_NAME="chikitsak_db"

# --- APP CONFIGURATION ---
PORT=5000
APP_URL="http://localhost:3000"
BACKEND_URL="http://127.0.0.1:5000"
